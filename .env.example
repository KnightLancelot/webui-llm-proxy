# ==================== Server ====================
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
# 单个 key：PROXY_API_KEY=sk-your-secret-key
# 多个 key（逗号分隔，方便团队协作）：PROXY_API_KEY=sk-key1,sk-key2,sk-key3
PROXY_API_KEY=
PROXY_MODEL_NAME=gemini-pro-via-proxy
PROXY_MAX_CONTEXT=8000

# ==================== Logging ====================
PROXY_LOG_LEVEL=INFO

# ==================== Session ====================
PROXY_KEEP_CHAT=false

# ==================== Browser ====================
PROXY_BROWSER_HEADLESS=false
PROXY_BROWSER_SLOW_MO=50
PROXY_BROWSER_WIDTH=1280
PROXY_BROWSER_HEIGHT=800
PROXY_BROWSER_USER_DATA_DIR=./browser_data_chrome
PROXY_KIMI_BROWSER_USER_DATA_DIR=./browser_data_kimi_v2
PROXY_BROWSER_POOL_SIZE=1
PROXY_USE_LOCAL_CHROME=true
PROXY_CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
PROXY_CHROME_CHANNEL=chrome

# ==================== Gemini ====================
PROXY_GEMINI_CHAT_URL=https://gemini.google.com/app
PROXY_GEMINI_AUTO_LOGIN=true
PROXY_GEMINI_LOGIN_WAIT_TIMEOUT=120
PROXY_GEMINI_PAGE_LOAD_WAIT=3
PROXY_GEMINI_RESPONSE_START_TIMEOUT=60
PROXY_GEMINI_STREAM_IDLE_TIMEOUT=30
PROXY_GEMINI_POLL_INTERVAL_MS=200

# Gemini DOM Selectors (override if UI changes)
# PROXY_GEMINI_INPUT_SELECTOR=div[role="textbox"]
# PROXY_GEMINI_SEND_SELECTOR=button.send-button
# PROXY_GEMINI_RESPONSE_SELECTOR=.response-content

# ==================== Kimi ====================
PROXY_KIMI_CHAT_URL=https://kimi.moonshot.cn
PROXY_KIMI_AUTO_LOGIN=true
PROXY_KIMI_LOGIN_WAIT_TIMEOUT=120
PROXY_KIMI_PAGE_LOAD_WAIT=3
PROXY_KIMI_RESPONSE_START_TIMEOUT=60
PROXY_KIMI_STREAM_IDLE_TIMEOUT=180
PROXY_KIMI_MAX_WAIT_AFTER_START=180
PROXY_KIMI_STABLE_COUNT_THRESHOLD=45
PROXY_KIMI_POLL_INTERVAL_MS=1000

# Kimi DOM Selectors (override if UI changes)
# PROXY_KIMI_INPUT_SELECTOR=textarea, div[contenteditable="true"]
# PROXY_KIMI_SEND_SELECTOR=button[type="submit"]
# PROXY_KIMI_RESPONSE_SELECTOR=.chat-message-assistant

# ==================== Upload ====================
PROXY_UPLOAD_TEMP_DIR=./data/uploads
PROXY_UPLOAD_MAX_SIZE_MB=100
PROXY_UPLOAD_MAX_FILES=10
PROXY_UPLOAD_PROCESSING_TIMEOUT=30

# ==================== Memory ====================
PROXY_SHORT_TERM_ROUNDS=20
PROXY_LONG_TERM_THRESHOLD=10
PROXY_MEMORY_FILE=./data/memory.json
PROXY_ENABLE_LONG_TERM=true
